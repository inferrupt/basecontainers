# Local host commands for the chae1 development container.

WORKSPACE_DIR := justfile_directory()
BASE_COMPOSE_FILE := WORKSPACE_DIR + "/compose.yaml"
BUILD_COMPOSE_FILE := WORKSPACE_DIR + "/compose.build.yaml"
PIN_ENV_FILE := WORKSPACE_DIR + "/.env.sha"
PIN_SCRIPT := WORKSPACE_DIR + "/scripts/pin-image.sh"
DEFAULT_WORKSPACE_PATH := WORKSPACE_DIR + "/../../../workspace_agent"
WORKSPACE_PATH_VALUE := env_var_or_default("AGENT_WORKSPACE", DEFAULT_WORKSPACE_PATH)
WORKSPACE_NAME_VALUE := env_var_or_default("WORKSPACE_NAME", "workspace")
IMAGE_REPO := env_var_or_default("IMAGE_REPO", "ghcr.io/geoff-hill/chae1-devcontainer")

_workspace-guard:
	@git -C "{{WORKSPACE_PATH_VALUE}}" rev-parse --is-inside-work-tree >/dev/null 2>&1 || (echo "error: missing workspace git checkout: {{WORKSPACE_PATH_VALUE}}" >&2; exit 1)

_compose +args:
	@if [ -f "{{PIN_ENV_FILE}}" ]; then \
		env AGENT_WORKSPACE='{{WORKSPACE_PATH_VALUE}}' WORKSPACE_NAME='{{WORKSPACE_NAME_VALUE}}' docker compose --project-directory {{WORKSPACE_DIR}} --env-file {{PIN_ENV_FILE}} -f {{BASE_COMPOSE_FILE}} {{args}}; \
	else \
		env AGENT_WORKSPACE='{{WORKSPACE_PATH_VALUE}}' WORKSPACE_NAME='{{WORKSPACE_NAME_VALUE}}' docker compose --project-directory {{WORKSPACE_DIR}} -f {{BASE_COMPOSE_FILE}} {{args}}; \
	fi

_compose-build +args:
	@if [ -f "{{PIN_ENV_FILE}}" ]; then \
		env AGENT_WORKSPACE='{{WORKSPACE_PATH_VALUE}}' WORKSPACE_NAME='{{WORKSPACE_NAME_VALUE}}' docker compose --project-directory {{WORKSPACE_DIR}} --env-file {{PIN_ENV_FILE}} -f {{BASE_COMPOSE_FILE}} -f {{BUILD_COMPOSE_FILE}} {{args}}; \
	else \
		env AGENT_WORKSPACE='{{WORKSPACE_PATH_VALUE}}' WORKSPACE_NAME='{{WORKSPACE_NAME_VALUE}}' docker compose --project-directory {{WORKSPACE_DIR}} -f {{BASE_COMPOSE_FILE}} -f {{BUILD_COMPOSE_FILE}} {{args}}; \
	fi

# List the available chae1 host commands.
default:
	just --list

# Start the chae1 container using the pinned registry image when available.
up:
	just _workspace-guard
	just _compose up -d dev

# Build the local chae1 image using cached layers.
build:
	just _workspace-guard
	just _compose-build build dev

# Rebuild the local chae1 image from scratch without cached layers.
rebuild:
	just _workspace-guard
	just _compose-build build --no-cache dev

# Start the chae1 container using the local Dockerfile build override.
up-build:
	just _workspace-guard
	just _compose-build up -d dev

# Remove the chae1 container and its persisted home volume.
home-remove:
	just _compose down --volumes --remove-orphans

# Open a shell in the chae1 container using the pinned registry image path.
shell:
	just up
	just _compose exec -u agent dev bash -l

# Open a shell in the chae1 container using the local build path.
shell-build:
	just up-build
	just _compose-build exec -u agent dev bash -l

# Open the mounted workspace in VS Code using the pinned registry image path.
code:
	just up
	@CID=$$(just _compose ps -q dev); \
	[ -n "$$CID" ] || { echo "error: could not resolve container id for dev" >&2; exit 1; }; \
	AUTH=$$(printf '%s' "$$CID" | xxd -p -c 256); \
	code -n --folder-uri "vscode-remote://attached-container+$$AUTH/workspaces/{{WORKSPACE_NAME_VALUE}}"

# Open the mounted workspace in VS Code using the local build path.
code-build:
	just up-build
	@CID=$$(just _compose-build ps -q dev); \
	[ -n "$$CID" ] || { echo "error: could not resolve container id for dev" >&2; exit 1; }; \
	AUTH=$$(printf '%s' "$$CID" | xxd -p -c 256); \
	code -n --folder-uri "vscode-remote://attached-container+$$AUTH/workspaces/{{WORKSPACE_NAME_VALUE}}"

# Stop the running chae1 container.
down:
	just _compose stop dev

# Pin the current registry `latest` image digest into `.env.sha`.
pin-latest:
	@{{PIN_SCRIPT}} IMAGE {{IMAGE_REPO}} {{PIN_ENV_FILE}}
